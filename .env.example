# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# YouTube Data API v3 (для поиска)
YOUTUBE_API_KEY=your_youtube_api_key

# VK API (service token для поиска)
VK_TOKEN=your_vk_service_token

# OpenAI (транскрипция Whisper + генерация текстов GPT)
OPENAI_API_KEY=your_openai_api_key

# Instagram Graph API (публикация Reels)
INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id

# VK (user token для публикации, scope: video,wall)
VK_USER_TOKEN=your_vk_user_token
VK_GROUP_ID=your_vk_group_id

# Max Messenger (публикация постов в канал)
MAX_BOT_TOKEN=your_max_bot_token
MAX_CHAT_ID=your_max_channel_chat_id

# YouTube OAuth2 (для загрузки видео)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
